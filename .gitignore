# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
**/.next-build/
/out/

# production
/build

# misc
.DS_Store
*.pem
.vector-cache/
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.out.log
*.err.log

# env files (can opt-in for committing if needed)
.env*
!*.env.example

# Custom local artifacts and generated files
code-documentation.txt
*-result.json
*-body.json
*-request.json
*-error.txt
*-status.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
