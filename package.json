{
  "name": "plc-frontend-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["ui", "backend", "ai"],
  "scripts": {
    "dev:ui": "npm --workspace ui run dev",
    "dev:backend": "npm --workspace backend run dev",
    "dev:ai": "npm --workspace ai run dev",
    "dev": "node scripts/workspaceRunner.js dev",
    "build:ui": "npm --workspace ui run build",
    "build:backend": "npm --workspace backend run build",
    "build:ai": "npm --workspace ai run build",
    "build": "npm run build:ai && npm run build:backend && npm run build:ui",
    "start": "node scripts/workspaceRunner.js start",
    "lint": "npm --workspace ui run lint",
    "rag:init": "node --import tsx scripts/initializeRAG.js",
    "rag:init:mock": "node --import tsx scripts/initializeRAGMock.js",
    "rag:clear": "node --import tsx scripts/clearRAG.js",
    "rag:diag": "node --import tsx scripts/diagnostics.js",
    "rag:test": "node --import tsx scripts/testPipeline.js",
    "fix-dev": "fix-dev.bat"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
